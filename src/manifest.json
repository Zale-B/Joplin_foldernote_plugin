{
	"manifest_version": 1,
	"id": "joplin.plugin.foldernote",
	"app_min_version": "3.5",
	"version": "1.0.0",
	"name": "Joplin Folder Note",
	"description": "Create an index note containing the contents of current notebook",
	"author": "Zale-B",
	"homepage_url": "https://github.com/Zale-B/Joplin_foldernote_plugin",
	"repository_url": "https://github.com/Zale-B/Joplin_foldernote_plugin",
	"keywords": ["folder note", "index note"],
	"categories": ["productivity"],
	"screenshots": [
		{ "src": "images/screenshot.png", "label": "Screenshot: Shows generated index note" },
		{ "src": "images/toolbar_icon.png", "label": "Screenshot: Shows the toolbar icon" },
		{ "src": "images/update_note.png", "label": "Screenshot: Shows the message dialog" }
	],
	"icons": {
		"32": "images/icon-32.png",
		"48": "images/icon-48.png",
		"128": "images/icon-128.png",
		"256": "images/icon-256.png"
	},
	"promo_tile": {
		"src": "images/promo_tile.png",
		"label": "Generate an index note for the current notebook"
	}
}